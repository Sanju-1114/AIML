import pandas as pd


df = pd.read_csv("raw_data.csv")


# Feature Engineering

df2 = df.copy()

# apply()
df2["tax"] = df2["income"].apply(lambda x : "20%" if x >= 50000 else "10%")


# map()
# Male => M, Female => F, Unknown => U
gender_map = {"Male" : "M", "Female" : "F", "Unknown" : "U"}
df2["gender"] = df2["gender"].map(gender_map)

# assign()
df2 = df2.assign(new_income = df2["income"] * 1.1)


# replace()
df2["country"] = df2["country"].replace("USA", "United States")

# rename()
df2.columns = ["Id", "Name", "Age", "Country", "Gender", "Income", "Tax", "New_Income"]
df2.rename(columns = {"Income" : "Salary"})

# sort()
df2.sort_values("Income")
df2.sort_values("Income", ascending=False)
sorted_df = df2.sort_values(["Income", "Age"])

sorted_df.sort_index()

# reset
sorted_df.reset_index()
sorted_df.reset_index(drop=True)

# Ranking - rank()
sorted_df["Ranking"] = sorted_df["Income"].rank()
sorted_df["Ranking"] = sorted_df["Income"].rank(ascending=False)
sorted_df["Ranking"] = sorted_df["Income"].rank(ascending=False, method="dense")
sorted_df["Ranking"] = sorted_df["Income"].rank(ascending=False, method="min")
sorted_df["Ranking"] = sorted_df["Income"].rank(ascending=False, method="max")

# Reorder Columns
sorted_df[["Id", "Name", "Age", "Country", "Gender", "Income", "New_Income", "Tax"]]



df2 = df.copy()

# new_col_order = ["name", "age", "country", "gender", "income", "id"]
new_col_order = [col for col in df2.columns if col != "id"] + ["id"]
# new_col_order
df2[new_col_order]



